# Only allow known safe file types to be served from this directory
<FilesMatch "\.(?!(pdf|jpg|jpeg|png|gif|webp|txt|md|csv|zip)$)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable PHP execution
<FilesMatch "\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# No directory listing
Options -Indexes
